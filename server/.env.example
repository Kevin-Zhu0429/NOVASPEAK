LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace-with-your-livekit-api-key
LIVEKIT_API_SECRET=replace-with-your-livekit-api-secret
PORT=3001
GUEST_SESSION_SECRET=replace-with-a-long-random-secret
MUSIC_CREDENTIAL_KEY=
# 可选：自定义 FFmpeg 可执行文件的绝对路径。
# 留空使用 npm 自动安装的内置 ffmpeg-static（推荐，无需手动装 FFmpeg）。
# 一旦配置则视为权威覆盖：必须是存在的绝对路径且可执行，
# 配置无效时音乐播放会暂停等待修复，不会自动回退内置解码器。
FFMPEG_PATH=
