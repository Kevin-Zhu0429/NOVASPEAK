{
  "name": "novaspeak-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "NovaSpeak 桌面客户端（NOVA GAMING 战队语音）",
  "author": "NOVA GAMING",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build:renderer": "node scripts/build-renderer.js",
    "dist": "npm run build:renderer && electron-builder --win nsis",
    "dist:dir": "npm run build:renderer && electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "top.novagaming.novaspeak",
    "productName": "NovaSpeak",
    "electronLanguages": ["zh-CN", "en-US"],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "app-config.json",
      "renderer/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "NovaSpeak",
      "artifactName": "NovaSpeak-Setup-${version}.${ext}"
    }
  }
}
